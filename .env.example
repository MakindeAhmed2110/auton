# Site URL for Open Graph / Twitter link previews (no trailing slash)
# VITE_SITE_URL=https://www.autonaisol.xyz

# Auton backend API
VITE_AUTON_API_URL=https://api.autonaisol.xyz

# Privy auth
VITE_PRIVY_APP_ID=

# $AUTO token — set when the token launches
VITE_AUTO_TOKEN_MINT=
VITE_AUTO_STAKE_POOL=
VITE_AUTO_REWARD_MINT=
VITE_AUTO_TOKEN_DECIMALS=9
VITE_AUTO_REWARD_DECIMALS=6
VITE_AUTO_TOTAL_SUPPLY=1000000000
VITE_AUTO_TREASURY_API_URL=

# Solana RPC (Helius recommended)
VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
VITE_SOLANA_CLUSTER=mainnet-beta
